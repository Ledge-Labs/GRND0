# Grants are explicit and disabled by default.
GRND0_ALLOW_WEB=0
# Local repository retrieval remains disabled until the git profile is started.
GRND0_ALLOW_GIT=0
# Cloud inference remains disabled until an accelerator lane is configured.
GRND0_ENABLE_CLOUD_ACCELERATOR=0
# Native host GPU inference remains disabled until its local service is started.
GRND0_ENABLE_HOST_GPU=0
# Host or WSL model endpoints remain disabled until explicitly connected.
GRND0_ENABLE_OPERATOR_LOCAL=0
# JSON array of container paths granted for read-only local knowledge access.
GRND0_AUTHORIZED_READ_ROOTS=[]

# Published services bind to loopback unless the authenticated operator changes this value.
GRND0_BIND_HOST=127.0.0.1
# Public OpenAI- and Anthropic-compatible endpoint port.
GRND0_ORCHESTRATOR_PORT=8000
# Public llama-swap status and compatible inference port.
GRND0_INFERENCE_PORT=9292
# Local Gitea port used by the git capability profile.
GRND0_GITEA_PORT=3000

# bootstrap-env generates this endpoint credential; no fixed credential ships.
GRND0_API_KEY=
# bootstrap-env generates this orchestrator-to-gateway credential.
GRND0_GATEWAY_TOKEN=
# bootstrap-env generates this internal capability-service credential.
GRND0_CAPABILITY_TOKEN=
# Gitea administrator name paired with generated credentials.
GRND0_GITEA_USERNAME=grnd0-admin
# bootstrap-env generates this Gitea administrator password.
GRND0_GITEA_PASSWORD=
# bootstrap-env generates a non-routable Gitea administrator email.
GRND0_GITEA_EMAIL=

# Optional digest-pinned llama-swap-compatible image override.
GRND0_INFERENCE_IMAGE=
# Host directory containing untracked operator model artifacts.
GRND0_MODELS_PATH=./models
# Host directory containing public or operator-authored packs.
GRND0_PACKS_PATH=./packs
# Pack used to generate the local inference configuration.
GRND0_INFERENCE_PACK=reference-chat
# Lane and backend map mounted into the core services.
GRND0_LANES_FILE=./configs/lanes.example.json

# Authentication remains mandatory for any non-loopback bind.
GRND0_AUTH_REQUIRED=true
# Internal gateway URL used by the orchestrator container.
GRND0_GATEWAY_URL=http://inference_gateway:8080
# Optional OpenAI-compatible cloud accelerator base URL.
GRND0_PROVIDER_BASE_URL=
# Optional cloud accelerator credential; never written to receipts.
GRND0_PROVIDER_API_KEY=
# Optional cloud accelerator model identifier.
GRND0_PROVIDER_MODEL=
# Local URL reached by containers when the native host GPU service is granted.
GRND0_HOST_GPU_BASE_URL=http://host.docker.internal:9292/v1
# Local URL reached by containers for an operator-managed host or WSL model.
GRND0_OPERATOR_LOCAL_BASE_URL=http://host.docker.internal:9300/v1
# Stub inference is reserved for deterministic clean-install verification.
GRND0_STUB_MODE=false
# Verbose health routes remain disabled by default.
GRND0_DEBUG_ROUTES=false

# Embedded SQLite state and receipt database inside the orchestrator volume.
GRND0_DATABASE_PATH=/var/lib/grnd0/state.sqlite
# Container path for the minimal named harness registry.
GRND0_HARNESS_PATH=/app/data/harness_templates
# Container path for the active lane map.
GRND0_LANES_PATH=/app/configs/lanes.example.json
# Container path for operator knowledge-source declarations.
GRND0_SOURCES_PATH=/app/configs/knowledge-sources.example.json
